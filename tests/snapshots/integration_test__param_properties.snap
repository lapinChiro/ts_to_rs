#[derive(Debug, Clone, PartialEq)]
struct Point {
    x: f64,
    y: f64,
}

impl Point {
    fn new(x: f64, y: f64) -> Self {
        Self { x, y }
    }
}

#[derive(Debug, Clone, PartialEq)]
struct Config {
    name: String,
    value: f64,
    pub(crate) level: f64,
}

impl Config {
    fn new(name: String, value: f64, level: f64) -> Self {
        Self { name, value, level }
    }
}

#[derive(Debug, Clone, PartialEq)]
struct Immutable {
    id: f64,
}

impl Immutable {
    fn new(id: f64) -> Self {
        Self { id }
    }
}

#[derive(Debug, Clone, PartialEq)]
struct Mixed {
    extra: f64,
    label: String,
}

impl Mixed {
    fn new(label: String, count: f64) -> Self {
        Self { label: label, extra: count * 2.0 }
    }
}

#[derive(Debug, Clone, PartialEq)]
struct WithDefault {
    size: f64,
}

impl WithDefault {
    fn new(size: f64) -> Self {
        Self { size }
    }
}
