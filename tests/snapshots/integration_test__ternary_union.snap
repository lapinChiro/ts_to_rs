#[derive(Debug, Clone, PartialEq)]
pub enum F64OrString {
    String(String),
    F64(f64),
}

impl std::fmt::Display for F64OrString {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            F64OrString::String(v) => write!(f, "{}", v),
            F64OrString::F64(v) => write!(f, "{}", v),
        }
    }
}

fn getStringOrNumber(flag: bool) -> F64OrString {
    if flag { F64OrString::String("hello".to_string()) } else { F64OrString::F64(42.0) }
}

fn getEitherString(flag: bool) -> String {
    if flag { "yes".to_string() } else { "no".to_string() }
}
