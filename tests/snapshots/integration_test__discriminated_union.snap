#[derive(Debug, Clone, PartialEq)]
pub enum Event {
    Click {
        x: f64,
    },
    Hover {
        y: f64,
    },
}

impl Event {
    pub fn kind(&self) -> &str {
        match self {
            Event::Click { .. } => "click",
            Event::Hover { .. } => "hover",
        }
    }
}

#[derive(Debug, Clone, PartialEq)]
pub enum Status {
    Active,
    Inactive,
    Pending,
}

impl Status {
    pub fn r#type(&self) -> &str {
        match self {
            Status::Active => "active",
            Status::Inactive => "inactive",
            Status::Pending => "pending",
        }
    }
}
