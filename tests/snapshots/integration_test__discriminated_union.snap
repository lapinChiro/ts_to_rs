#[derive(Debug, Clone, PartialEq)]
pub enum Event {
    Click {
        x: f64,
    },
    Hover {
        y: f64,
    },
}

impl Event {
    pub fn kind(&self) -> &str {
        match self {
            Event::Click { .. } => "click",
            Event::Hover { .. } => "hover",
        }
    }
}

#[derive(Debug, Clone, PartialEq)]
pub enum Status {
    Active,
    Inactive,
    Pending,
}

impl Status {
    pub fn r#type(&self) -> &str {
        match self {
            Status::Active => "active",
            Status::Inactive => "inactive",
            Status::Pending => "pending",
        }
    }
}

fn handleEvent(event: Event) -> String {
    match &event {
        Event::Click { x, .. } => {
            return format!("clicked at {}", x.clone());
        }
        Event::Hover { y, .. } => {
            return format!("hovered at {}", y.clone());
        }
    }
}

fn describeStatus(status: Status) -> String {
    match &status {
        Status::Active => {
            return "active".to_string();
        }
        Status::Inactive => {
            return "inactive".to_string();
        }
        Status::Pending => {
            return "pending".to_string();
        }
    }
}

#[derive(Debug, Clone, PartialEq)]
enum Shape {
    Circle {
        radius: f64,
    },
    Rect {
        width: f64,
        height: f64,
    },
}

impl Shape {
    pub fn kind(&self) -> &str {
        match self {
            Shape::Circle { .. } => "circle",
            Shape::Rect { .. } => "rect",
        }
    }
}

fn area(shape: Shape) -> f64 {
    match &shape {
        Shape::Circle { radius, .. } => {
            return std::f64::consts::PI * radius.clone() * radius.clone();
        }
        Shape::Rect { height, width, .. } => {
            return width.clone() * height.clone();
        }
    }
}
