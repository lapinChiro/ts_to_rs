#[derive(Debug, Clone, PartialEq)]
pub enum F64OrString {
    String(String),
    F64(f64),
}

#[derive(Debug, Clone, PartialEq)]
pub enum ProcessObjectXType {
    Object(serde_json::Value),
    Other(serde_json::Value),
}

#[derive(Debug, Clone, PartialEq)]
pub enum UnknownTypeofXType {
    String(String),
    Other(serde_json::Value),
}

fn processOptional(x: Option<String>) {
    if let Some(x) = x {
        println!("{}", x);
    }
}

fn processUnion(x: F64OrString) -> String {
    let x = match x {
    F64OrString::String(x) => {
        return x.trim().to_string();
    }
    F64OrString::F64(x) => {
        x
    }
};
    "not a string".to_string()
}

fn processObject(x: ProcessObjectXType) {
    if let ProcessObjectXType::Object(x) = x {
        println!("{}", x);
    }
}

fn processCompound(x: F64OrString, y: F64OrString) {
    if let F64OrString::String(x) = x {
        if let F64OrString::F64(y) = y {
            println!("{}", x.len() as f64);
            println!("{}", y.toFixed(2.0));
        }
    }
}

fn processMixed(x: F64OrString, y: Option<String>) {
    if let F64OrString::String(x) = x {
        if let Some(y) = y {
            println!("{}", x.len() as f64);
            println!("{}", y);
        }
    }
}

fn processGuardAndCondition(x: F64OrString) {
    if let F64OrString::String(x) = x {
        if x.len() as f64 > 0.0 {
            println!("{}", x);
        }
    }
}

fn processCompoundWithElse(x: F64OrString, y: F64OrString) -> String {
    if let F64OrString::String(x) = x {
        if let F64OrString::F64(y) = y {
            return x.trim().to_string();
        } else {
            return "fallback".to_string();
        }
    } else {
        return "fallback".to_string();
    }
}

fn processGuardConditionElse(x: F64OrString) -> String {
    if let F64OrString::String(x) = x {
        if x.len() as f64 > 0.0 {
            return x;
        } else {
            return "empty or not string".to_string();
        }
    } else {
        return "empty or not string".to_string();
    }
}

fn processNeqCompound(x: F64OrString, y: Option<String>) {
    if let F64OrString::F64(x) = x {
        println!("fallback");
    } else {
        if let Some(y) = y {
            println!("{}", x);
            println!("{}", y);
        } else {
            println!("fallback");
        }
    }
}

fn ternaryTypeof(x: F64OrString) -> f64 {
    if let F64OrString::String(x) = x { x.len() as f64 } else { 0.0 }
}

fn ternaryNullCheck(x: Option<String>) -> String {
    if let Some(x) = x { x.trim().to_string() } else { "default".to_string() }
}

fn ternaryNoGuard(a: f64) -> String {
    if a > 0.0 { "positive".to_string() } else { "non-positive".to_string() }
}

fn ternaryNeqTypeof(x: F64OrString) -> f64 {
    if let F64OrString::String(x) = x { x.len() as f64 } else { 0.0 }
}

fn switchTypeof(x: F64OrString) -> String {
    match x {
        F64OrString::String(x) => {
            return x.trim().to_string();
        }
        F64OrString::F64(x) => {
            return x.toFixed(2.0);
        }
        _ => {
            return "unknown".to_string();
        }
    }
}

fn switchTypeofNarrow(x: F64OrString) -> f64 {
    match x {
        F64OrString::String(x) => {
            return x.len() as f64;
        }
        _ => {
            return 0.0;
        }
    }
}

fn switchTypeofFallthrough(x: F64OrString) -> String {
    match x {
        F64OrString::String(x) => {
            return "primitive".to_string();
        }
        F64OrString::F64(x) => {
            return "primitive".to_string();
        }
        _ => {
            return "other".to_string();
        }
    }
}

fn eqNullWithElse(x: Option<String>) -> String {
    if let Some(x) = x {
        return x.trim().to_string();
    } else {
        return "null".to_string();
    }
}

fn eqUndefinedWithElse(x: Option<String>) -> String {
    if let Some(x) = x {
        return x.trim().to_string();
    } else {
        return "undefined".to_string();
    }
}

fn typeofNeqWithElse(x: F64OrString) -> String {
    match x {
        F64OrString::String(x) => {
            return x.trim().to_string();
        }
        F64OrString::F64(x) => {
            return "not string".to_string();
        }
    }
}

fn unknownTypeof(x: UnknownTypeofXType) -> String {
    if let UnknownTypeofXType::String(x) = x {
        return x.to_uppercase();
    }
    "not a string".to_string()
}

fn complementElse2(x: F64OrString) -> String {
    match x {
        F64OrString::String(x) => {
            return x.trim().to_string();
        }
        F64OrString::F64(x) => {
            return x.toFixed(2.0);
        }
    }
}

fn earlyReturnNarrowing(x: F64OrString) -> f64 {
    let x = match x {
    F64OrString::String(x) => {
        return x.len() as f64;
    }
    F64OrString::F64(x) => {
        x
    }
};
    x
}

fn earlyReturnNull(x: Option<String>) -> String {
    let x = match x {
    None => {
        return "null".to_string();
    }
    Some(x) => {
        x
    }
};
    x.trim().to_string()
}

fn compoundTernary(x: F64OrString, y: Option<String>) -> f64 {
    if let F64OrString::String(x) = x { if let Some(y) = y { x.len() as f64 } else { 0.0 } } else { 0.0 }
}
