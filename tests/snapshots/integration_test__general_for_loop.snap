fn countdown(n: f64) {
    let mut i = n;
    loop {
        if !(i >= 0.0) {
            break;
        }
        println!("{}", i);
        i = i - 1.0;
    }
}

fn stepByTwo(n: f64) {
    let mut i = 0.0;
    loop {
        if !(i < n) {
            break;
        }
        println!("{}", i);
        i = i + 2.0;
    }
}
