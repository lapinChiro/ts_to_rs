fn countdown(n: f64) {
    let mut i = n;
    loop {
        if !(i >= 0.0) {
            break;
        }
        println!("{}", i);
        i = i - 1.0;
    }
}

fn stepByTwo(n: f64) {
    let mut i = 0.0;
    loop {
        if !(i < n) {
            break;
        }
        println!("{}", i);
        i = i + 2.0;
    }
}

fn findFirst(items: Vec<f64>, target: f64) -> f64 {
    let mut result = -1.0;
    for i in 0..items.len() as f64 as i64 {
        let i = i as f64;
        if items.get(i as usize).cloned() == target {
            result = i;
            break;
        }
    }
    result
}

fn sumEven(n: f64) -> f64 {
    let mut total = 0.0;
    for i in 0..n as i64 {
        let i = i as f64;
        if i % 2.0 != 0.0 {
            continue;
        }
        total = total + i;
    }
    total
}

fn multiplicationTable(n: f64) -> f64 {
    let mut count = 0.0;
    let mut i = 1.0;
    loop {
        if !(i <= n) {
            break;
        }
        let mut j = 1.0;
        loop {
            if !(j <= n) {
                break;
            }
            {
    let _old = count;
    count = count + 1.0;
    _old
};
            j = j + 1.0;
        }
        i = i + 1.0;
    }
    count
}

fn sumOfSquares(n: f64) -> f64 {
    let mut result = 0.0;
    let mut i = 1.0;
    loop {
        if !(i <= n) {
            break;
        }
        result = result + i * i;
        i = i + 1.0;
    }
    result
}
