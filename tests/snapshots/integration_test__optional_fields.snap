---
source: tests/integration_test.rs
expression: output
---
#[derive(Debug, Clone, PartialEq)]
struct Config {
    host: String,
    port: f64,
    debug: Option<bool>,
    label: Option<String>,
}

#[derive(Debug, Clone, PartialEq)]
struct UserProfile {
    name: String,
    email: Option<String>,
    age: Option<f64>,
    bio: Option<String>,
}

fn getPort(config: Config) -> f64 {
    config.port
}

fn isDebug(config: Config) -> bool {
    config.debug.unwrap_or(false)
}

#[derive(Debug, Clone, PartialEq)]
struct Address {
    street: String,
    city: String,
    zip: Option<String>,
}

#[derive(Debug, Clone, PartialEq)]
struct Person {
    name: String,
    address: Option<Address>,
}
