trait Greeter {
    fn greet(&self) -> String;
}

fn useGreeter(g: &dyn Greeter) -> String {
    g.greet()
}

fn createGreeter() -> Box<dyn Greeter> {
    None
}

fn testBoxToRef() {
    let mut g: Box<dyn Greeter> = createGreeter();
    useGreeter(g);
}

#[derive(Debug, Clone, PartialEq)]
struct MyGreeter {
}

impl Greeter for MyGreeter {
    fn greet(&self) -> String {
        "hello".to_string()
    }
}

fn testConcreteToBox() {
    let mut g: Box<dyn Greeter> = Box::new(MyGreeter::new());
}

fn testReturn() -> Box<dyn Greeter> {
    let mut g: Box<dyn Greeter> = createGreeter();
    g
}

#[derive(Debug, Clone, PartialEq)]
struct Point {
    x: f64,
    y: f64,
}

fn usePoint(p: Point) -> f64 {
    p.x
}
