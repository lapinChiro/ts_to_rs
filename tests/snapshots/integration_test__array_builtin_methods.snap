fn processNumbers(nums: Vec<f64>) -> Vec<f64> {
    nums.iter().cloned().map(|x| x * 2.0).collect::<Vec<_>>().iter().cloned().filter(|x| *x > 4.0).collect::<Vec<_>>()
}

fn getFirstPositive(nums: Vec<f64>) -> Option<f64> {
    let doubled = nums.iter().cloned().map(|x| x * 2.0).collect::<Vec<_>>();
    doubled.iter().cloned().find(|x| *x > 0.0)
}
