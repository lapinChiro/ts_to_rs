#[derive(Debug, Clone, PartialEq)]
pub struct TsBox<T> {
    pub value: T,
}

impl<T> TsBox<T> {
    pub fn new(val: T) -> Self {
        Self { value: val }
    }
}

#[derive(Debug, Clone, PartialEq)]
pub struct Pair<A, B> {
    pub first: A,
    pub second: B,
}

impl<A, B> Pair<A, B> {
    pub fn new(a: A, b: B) -> Self {
        Self { first: a, second: b }
    }
}

#[derive(Debug, Clone, PartialEq)]
pub struct Stack<T> {
    pub items: Vec<T>,
}

impl<T> Stack<T> {
    pub fn new() -> Self {
        Self { items: vec![] }
    }

    pub fn isEmpty(&self) -> bool {
        self.items.len() as f64 == 0.0
    }
}

#[derive(Debug, Clone, PartialEq)]
pub struct NumberBox {
    pub value: f64,
}

impl NumberBox {
    pub fn new(val: f64) -> Self {
        Self { value: val }
    }

    pub fn double(&self) -> f64 {
        self.value * 2.0
    }
}

#[derive(Debug, Clone, PartialEq)]
pub struct KeyValue<K, V> {
    pub key: K,
    pub value: V,
}

impl<K, V> KeyValue<K, V> {
    pub fn new(key: K, value: V) -> Self {
        Self { key, value }
    }
}
