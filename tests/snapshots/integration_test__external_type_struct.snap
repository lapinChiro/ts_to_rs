#[derive(Debug, Clone, PartialEq)]
pub struct ArrayBuffer {
    pub byte_length: f64,
    pub max_byte_length: f64,
    pub resizable: bool,
    pub detached: bool,
}

#[derive(Debug, Clone, PartialEq)]
pub enum ArrayBufferOrString {
    ArrayBuffer(ArrayBuffer),
    String(String),
}

impl std::fmt::Display for ArrayBufferOrString {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            ArrayBufferOrString::ArrayBuffer(v) => write!(f, "{:?}", v),
            ArrayBufferOrString::String(v) => write!(f, "{}", v),
        }
    }
}

#[derive(Debug, Clone, PartialEq)]
pub struct Date {
}

#[derive(Debug, Clone, PartialEq)]
pub struct Error {
    pub name: String,
    pub message: String,
    pub stack: Option<String>,
}

#[derive(Debug, Clone, PartialEq)]
pub enum DateOrError {
    Date(Date),
    Error(Error),
}

impl std::fmt::Display for DateOrError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            DateOrError::Date(v) => write!(f, "{:?}", v),
            DateOrError::Error(v) => write!(f, "{:?}", v),
        }
    }
}

pub fn processValue(input: ArrayBufferOrString) -> String {
    input.to_string()
}
