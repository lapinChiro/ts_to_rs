#[derive(Debug, Clone, PartialEq)]
struct Point {
    x: f64,
    y: f64,
}

fn overrideX(p: Point) -> Point {
    let p2: Point = Point { x: 10.0, y: p.y };
    p2
}

fn overrideMultiple(p: Point) -> Point {
    let p2: Point = Point { x: 10.0, y: 20.0 };
    p2
}

fn clonePoint(p: Point) -> Point {
    let p2: Point = Point { x: p.x, y: p.y };
    p2
}

fn spreadAtEnd(p: Point) -> Point {
    let p2: Point = Point { x: p.x, y: p.y };
    p2
}

#[derive(Debug, Clone, PartialEq)]
struct Config {
    a: f64,
    b: f64,
    c: f64,
}

fn spreadInMiddle(cfg: Config) -> Config {
    let c2: Config = Config { a: cfg.a, b: cfg.b, c: 3.0 };
    c2
}
