#[derive(Debug, Clone, PartialEq)]
pub enum HandleValueXType {
    Date(Date),
    Error(Error),
    RegExp(RegExp),
    Other(serde_json::Value),
}

impl std::fmt::Display for HandleValueXType {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            HandleValueXType::Date(v) => write!(f, "{:?}", v),
            HandleValueXType::Error(v) => write!(f, "{:?}", v),
            HandleValueXType::RegExp(v) => write!(f, "{:?}", v),
            HandleValueXType::Other(v) => write!(f, "{}", v),
        }
    }
}

fn handleValue(x: HandleValueXType) -> String {
    if let HandleValueXType::Date(x) = x {
        return x.toISOString();
    }
    if let HandleValueXType::Error(x) = x {
        return x.message;
    }
    if let HandleValueXType::RegExp(x) = x {
        return x.source;
    }
    String(x)
}
