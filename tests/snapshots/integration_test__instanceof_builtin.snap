#[derive(Debug, Clone, PartialEq)]
pub enum HandleValueXType {
    Date(Date),
    Error(Error),
    RegExp(RegExp),
    Other(serde_json::Value),
}

fn handleValue(x: HandleValueXType) -> String {
    if let HandleValueXType::Date(x) = x {
        return x.toISOString();
    }
    if let HandleValueXType::Error(x) = x {
        return x.message;
    }
    if let HandleValueXType::RegExp(x) = x {
        return x.source;
    }
    String(x)
}
