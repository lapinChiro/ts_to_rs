#[derive(Debug, Clone, PartialEq)]
struct Point {
    x: f64,
    y: f64,
}

#[derive(Debug, Clone, PartialEq)]
struct Config {
    count: f64,
    active: bool,
}

fn createPoint() -> Point {
    let mut p: Point = Point { x: 1.0, y: 2.0 };
    p
}

fn createConfig() -> Config {
    let mut c: Config = Config { count: 0.0, active: true };
    c
}

fn createPointShorthand(x: f64, y: f64) -> Point {
    let mut p: Point = Point { x, y };
    p
}

fn createMixed(x: f64) -> Point {
    let mut p: Point = Point { x: x, y: 10.0 };
    p
}
