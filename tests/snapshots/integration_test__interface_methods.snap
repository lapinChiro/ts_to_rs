trait Animal {
    fn speak(&self) -> String;
}

trait Dog: Animal {
    fn bark(&self) -> String;
}

#[derive(Debug, Clone, PartialEq)]
struct Point {
    x: f64,
    y: f64,
}

#[derive(Debug, Clone, PartialEq)]
struct Point3D {
    pub x: f64,
    pub y: f64,
    z: f64,
}

trait Readable {
    fn read(&self) -> String;
}

trait Writable {
    fn write(&self, data: String);
}

trait ReadWrite: Readable + Writable {
}
