fn toInt(s: String) -> f64 {
    s.parse::<f64>().unwrap_or(f64::NAN)
}

fn toFloat(s: String) -> f64 {
    s.parse::<f64>().unwrap_or(f64::NAN)
}

fn checkNaN(x: f64) -> bool {
    x.is_nan()
}

fn checkFinite(x: f64) -> bool {
    x.is_finite()
}
