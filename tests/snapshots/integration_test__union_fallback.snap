enum StringOrFn {
    String(String),
    Fn(Box<dyn Fn(f64) -> String>),
}

#[derive(Debug, Clone, PartialEq)]
enum StringOrTuple {
    String(String),
    Tuple((f64, String)),
}

impl std::fmt::Display for StringOrTuple {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            StringOrTuple::String(v) => write!(f, "{}", v),
            StringOrTuple::Tuple(v) => write!(f, "{:?}", v),
        }
    }
}

enum Mixed {
    String(String),
    Fn(Box<dyn Fn(f64)>),
    Tuple((bool, f64)),
}

#[derive(Debug, Clone, PartialEq)]
enum StringOrNumber {
    String(String),
    F64(f64),
}

impl std::fmt::Display for StringOrNumber {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            StringOrNumber::String(v) => write!(f, "{}", v),
            StringOrNumber::F64(v) => write!(f, "{}", v),
        }
    }
}
