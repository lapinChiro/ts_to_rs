#[derive(Debug, Clone, PartialEq)]
enum StringOrFn {
    String(String),
    Fn(Box<dyn Fn(f64) -> String>),
}

#[derive(Debug, Clone, PartialEq)]
enum StringOrTuple {
    String(String),
    Tuple((f64, String)),
}

#[derive(Debug, Clone, PartialEq)]
