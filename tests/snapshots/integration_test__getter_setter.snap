#[derive(Debug, Clone, PartialEq)]
struct Counter {
    _count: f64,
}

impl Counter {
    fn count(&self) -> f64 {
        self._count
    }
}

#[derive(Debug, Clone, PartialEq)]
struct Writer {
    _name: String,
}

impl Writer {
    fn set_name(&mut self, value: String) {
        self._name = value;
    }
}

#[derive(Debug, Clone, PartialEq)]
struct Person {
    _age: f64,
}

impl Person {
    fn age(&self) -> f64 {
        self._age
    }

    fn set_age(&mut self, value: f64) {
        self._age = value;
    }
}

#[derive(Debug, Clone, PartialEq)]
struct Config {
    _debug: bool,
}

impl Config {
    fn debug(&self) -> bool {
        self._debug
    }

    fn toggle(&mut self) {
        self._debug = !self._debug;
    }
}

#[derive(Debug, Clone, PartialEq)]
struct ClickCounter {
    _count: f64,
}

impl ClickCounter {
    fn increment(&mut self) {
        self._count = self._count + 1.0;
    }

    fn get_count(&self) -> f64 {
        self._count
    }
}

fn useCounter(counter: ClickCounter) -> f64 {
    let mut counter = counter;
    counter.increment();
    counter.get_count()
}
