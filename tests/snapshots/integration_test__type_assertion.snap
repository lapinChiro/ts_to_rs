#[derive(Debug, Clone, PartialEq)]
pub enum F64OrString {
    String(String),
    F64(f64),
}

impl std::fmt::Display for F64OrString {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            F64OrString::String(v) => write!(f, "{}", v),
            F64OrString::F64(v) => write!(f, "{}", v),
        }
    }
}

fn passThrough(x: serde_json::Value) -> serde_json::Value {
    x
}

fn assertString(x: String) -> String {
    x
}

fn assertNumber(x: f64) -> f64 {
    x as f64
}

fn getLength(x: serde_json::Value) -> f64 {
    x.len() as f64
}

fn processValue(input: serde_json::Value) -> serde_json::Value {
    let str = input;
    str
}

fn forceConvert(x: f64) -> String {
    x
}

fn narrowToString(x: F64OrString) -> String {
    x
}
