#[derive(Debug, Clone, PartialEq)]
pub enum CheckArrowXType {
    String(String),
    Other(serde_json::Value),
}

impl std::fmt::Display for CheckArrowXType {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            CheckArrowXType::String(v) => write!(f, "{}", v),
            CheckArrowXType::Other(v) => write!(f, "{}", v),
        }
    }
}

