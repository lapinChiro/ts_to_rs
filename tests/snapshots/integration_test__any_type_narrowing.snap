fn processAny(x: ProcessAnyXType) {
    if let ProcessAnyXType::String(x) = x {
        println!("{}", x);
    }
}

fn passthrough(x: serde_json::Value) {
    println!("{}", x);
}

fn checkArrow(x: CheckArrowXType) {
    if let CheckArrowXType::String(x) = x {
        println!("{}", x);
    }
}

fn localAny(input: serde_json::Value) {
    let data: LocalAnyDataType = input;
    if let LocalAnyDataType::String(data) = data {
        println!("{}", data);
    }
}

fn exprArrow(x: ExprArrowXType) -> f64 {
    if let ExprArrowXType::String(x) = x { x.len() as f64 } else { 0.0 }
}
