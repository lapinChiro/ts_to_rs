#[derive(Debug, Clone, PartialEq)]
pub enum F64OrString {
    String(String),
    F64(f64),
}

fn abs(a: f64) -> f64 {
    let result = if a > 0.0 { a } else { 0.0 };
    result
}

fn sign(x: f64) -> String {
    if x > 0.0 { "positive".to_string() } else { "negative".to_string() }
}

fn signOrZero(x: f64) -> String {
    if x > 0.0 { "positive".to_string() } else { if x < 0.0 { "negative".to_string() } else { "zero".to_string() } }
}

fn pick(flag: bool, a: f64, b: f64) -> f64 {
    if flag { a } else { b }
}

fn formatValue(x: f64) -> String {
    if x > 0.0 { format!("+{}", x) } else { format!("{}", x) }
}

fn getLabel(active: bool) -> f64 {
    let label = if active { 1.0 } else { 0.0 };
    label
}

fn max(a: f64, b: f64) -> f64 {
    if a > b { a } else { b }
}

fn maybeValue(flag: bool) -> Option<String> {
    if flag { Some("value".to_string()) } else { None }
}

fn toDisplay(x: f64) -> F64OrString {
    if x > 0.0 { x } else { "negative" }
}
