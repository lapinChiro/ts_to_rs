#[derive(Debug, Clone, PartialEq)]
pub struct Container<T> {
    pub value: T,
}

#[derive(Debug, Clone, PartialEq)]
pub struct Pair<A, B> {
    pub first: A,
    pub second: B,
}

pub fn identity<T>(x: T) -> T {
    x
}

#[derive(Debug, Clone, PartialEq)]
pub struct UserList {
    pub users: Container<String>,
}

pub trait Processor<T> {
    fn process(&self, input: T) -> T;
}

pub trait Bounded<T: Processor<String>> {
    fn wrap(&self, item: T) -> T;
}
