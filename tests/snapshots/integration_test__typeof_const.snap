#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DetectorsKey {
    Querystring,
    Cookie,
    Header,
}

impl DetectorsKey {
    pub fn as_str(&self) -> &str {
        match self {
            DetectorsKey::Querystring => "querystring",
            DetectorsKey::Cookie => "cookie",
            DetectorsKey::Header => "header",
        }
    }
}

impl std::fmt::Display for DetectorsKey {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.as_str())
    }
}

