fn sumArray(arr: Vec<f64>) -> f64 {
    arr.iter().fold(0.0, |acc: f64, x: f64| acc + x)
}

fn findIndex(arr: Vec<f64>, target: f64) -> f64 {
    arr.iter().position(|item| *item == target)
}

fn joinWords(arr: Vec<String>, sep: String) -> String {
    arr.join(sep)
}

fn reverseArray(arr: Vec<f64>) {
    arr.reverse();
}

fn sortArray(arr: Vec<f64>) {
    arr.sort();
}

fn sortDescending(arr: Vec<f64>) {
    arr.sort_by(|a: f64, b: f64| b - a);
}

fn sliceArray(arr: Vec<f64>) -> Vec<f64> {
    arr[1..3].to_vec()
}

fn spliceArray(arr: Vec<f64>) -> Vec<f64> {
    arr.drain(1..1.0 + 2.0 as i64).collect::<Vec<_>>()
}

fn circleArea(r: f64) -> f64 {
    std::f64::consts::PI * r * r
}

fn signOf(x: f64) -> f64 {
    x.signum()
}

fn truncate(x: f64) -> f64 {
    x.trunc()
}

fn naturalLog(x: f64) -> f64 {
    x.ln()
}

fn isWholeNumber(x: f64) -> bool {
    x.fract() == 0.0
}
