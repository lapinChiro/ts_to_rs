#[derive(Debug, Clone, PartialEq)]
pub struct OmitConfigDebug {
    pub host: String,
    pub port: f64,
}

#[derive(Debug, Clone, PartialEq)]
pub struct PartialConfig {
    pub host: Option<String>,
    pub port: Option<f64>,
    pub debug: Option<bool>,
}

#[derive(Debug, Clone, PartialEq)]
pub struct PickConfigHost {
    pub host: String,
}

#[derive(Debug, Clone, PartialEq)]
pub struct RequiredPartialUser {
    pub name: String,
    pub age: f64,
}

#[derive(Debug, Clone, PartialEq)]
struct Config {
    host: String,
    port: f64,
    debug: bool,
}

type AppConfig = Config;

type OptionalConfig = PartialConfig;

#[derive(Debug, Clone, PartialEq)]
struct ExtendedConfig {
    host: String,
    port: f64,
    debug: bool,
    pub extra: String,
}

#[derive(Debug, Clone, PartialEq)]
struct Combined {
    pub a: f64,
    pub b: String,
}

#[derive(Debug, Clone, PartialEq)]
struct PartialUser {
    name: Option<String>,
    age: Option<f64>,
}

type FullUser = RequiredPartialUser;

type HostOnly = PickConfigHost;

type WithoutDebug = OmitConfigDebug;

type ReadonlyConfig = Config;

type StringMap = HashMap<String, f64>;

fn getHost(config: HostOnly) -> String {
    config.host
}

fn createConfig(host: String, port: f64) -> AppConfig {
    AppConfig { host: host, port: port, debug: false }
}
