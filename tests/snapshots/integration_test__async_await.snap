async fn fetchNumber() -> f64 {
    42.0
}

async fn fetchMessage() -> String {
    "done".to_string()
}

async fn noReturnType() {
    return;
}

#[tokio::main]
async fn main() {
    let num = fetchNumber().await;
    println!("{}", num);
}

async fn processData() -> String {
    let num = fetchNumber().await;
    let msg = fetchMessage().await;
    format!("{}: {}", msg, num)
}

async fn safeFetch() -> f64 {
    let result = fetchNumber().await;
    result
}

async fn delayedAdd(a: f64, b: f64) -> f64 {
    let sum = a + b;
    sum
}

async fn maybeFetch(flag: bool) -> Option<String> {
    if flag {
        return Some(fetchMessage().await);
    }
    None
}
