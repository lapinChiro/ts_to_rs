pub fn validateAge(age: f64) -> Result<String, String> {
    if age < 0.0 {
        return Err("age must be non-negative".to_string());
    }
    Ok("valid".to_string())
}

fn riskyOperation() -> Result<f64, String> {
    Err("not implemented".to_string())
}

pub fn safeDivide(a: f64, b: f64) -> Result<f64, String> {
    if b == 0.0 {
        return Err("division by zero".to_string());
    }
    Ok(a / b)
}

fn withTryCatch() {
    match (|| -> Result<(), String> {
        riskyOperation();
        Ok(())
    })() {
        Err(e) => {
            eprintln!("{:?}", e);
        }
        _ => {}
    }
}

fn withTryFinally() {
    let _finally_guard = scopeguard::guard((), |_| {
        println!("cleanup");
    });
    riskyOperation();
}

fn withTryCatchFinally() {
    let _finally_guard = scopeguard::guard((), |_| {
        println!("done");
    });
    match (|| -> Result<(), String> {
        riskyOperation();
        Ok(())
    })() {
        Err(e) => {
            eprintln!("{:?}", e);
        }
        _ => {}
    }
}
