pub fn validateAge(age: f64) -> Result<String, String> {
    if age < 0.0 {
        return Err("age must be non-negative".to_string());
    }
    Ok("valid".to_string())
}

fn riskyOperation() -> Result<f64, String> {
    Err("not implemented".to_string())
}

pub fn safeDivide(a: f64, b: f64) -> Result<f64, String> {
    if b == 0.0 {
        return Err("division by zero".to_string());
    }
    Ok(a / b)
}

fn withTryCatch() {
    let _try_result: Result<(), String> = 'try_block: {
        riskyOperation();
        Ok(())
    };
    if let Err(e) = _try_result {
        eprintln!("{:?}", e);
    }
}

fn withTryFinally() {
    let _finally_guard = scopeguard::guard((), |_| {
        println!("cleanup");
    });
    riskyOperation();
}

fn withTryCatchFinally() {
    let _finally_guard = scopeguard::guard((), |_| {
        println!("done");
    });
    let _try_result: Result<(), String> = 'try_block: {
        riskyOperation();
        Ok(())
    };
    if let Err(e) = _try_result {
        eprintln!("{:?}", e);
    }
}

fn withThrowInTryCatch(x: f64) {
    let _try_result: Result<(), String> = 'try_block: {
        if x < 0.0 {
            break 'try_block Err("negative".to_string());
        }
        println!("ok");
        Ok(())
    };
    if let Err(e) = _try_result {
        eprintln!("{:?}", e);
    }
}

fn withBreakInTryCatch(items: Vec<f64>) {
    for item in items {
        let _try_result: Result<(), String> = 'try_block: {
            if item < 0.0 {
                break;
            }
            riskyOperation();
            Ok(())
        };
        if let Err(e) = _try_result {
            eprintln!("{:?}", e);
        }
    }
}
